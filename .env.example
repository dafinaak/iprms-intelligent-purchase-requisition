# IPRMS — local environment configuration (EXAMPLE)
# Copy to .env and fill in ONLY if you enable the optional features.
# The deterministic core pipeline runs fully WITHOUT any of these.

# --- Optional: Agent B LLM extraction fallback (LangChain) ---
# Leave empty/unset to keep the pipeline 100% deterministic.
IPRMS_LLM_FALLBACK_ENABLED=false
# OPENAI_API_KEY=

# --- Optional: OCR engine for scanned PDFs (pytesseract) ---
# Path to the system Tesseract binary, if not on PATH.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- Optional: LangGraph internal A→H wrapper toggle ---
IPRMS_USE_LANGGRAPH=false
